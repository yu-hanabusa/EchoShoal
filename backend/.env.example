# EchoShoal Configuration
# Copy this to .env and fill in your values

# LLM - Ollama (local)
ECHOSHOAL_OLLAMA_BASE_URL=http://localhost:11434
ECHOSHOAL_OLLAMA_MODEL=qwen2.5:14b

# LLM - Claude API (for heavy tasks)
ECHOSHOAL_CLAUDE_API_KEY=
ECHOSHOAL_CLAUDE_MODEL=claude-sonnet-4-20250514

# LLM - OpenAI API (alternative for heavy tasks)
ECHOSHOAL_OPENAI_API_KEY=
ECHOSHOAL_OPENAI_MODEL=gpt-4o

# Which provider for heavy tasks: "claude" or "openai"
ECHOSHOAL_DEFAULT_HEAVY_PROVIDER=claude

# e-Stat API (政府統計データ)
ECHOSHOAL_ESTAT_API_KEY=

# Neo4j
ECHOSHOAL_NEO4J_URI=bolt://localhost:7687
ECHOSHOAL_NEO4J_USER=neo4j
ECHOSHOAL_NEO4J_PASSWORD=

# Redis
ECHOSHOAL_REDIS_URL=redis://localhost:6379

# Simulation
ECHOSHOAL_DEFAULT_ROUNDS=24
ECHOSHOAL_AGENT_ACTIVATION_RATE=0.4
ECHOSHOAL_MAX_ACTIONS_PER_AGENT=2
